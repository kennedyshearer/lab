#!/bin/bash

# AND - both must be true
if [[ -f "$1" && -r "$1" ]]; then
    echo "File exists and is readable"
    exit 0
elif [[ -d "$1" ]]; then
    echo "Directory exists"
    exit 0
fi

# OR - either can be true
if [[ -z "$1" || "$1" == "--help" ]]; then
    echo "Usage: $0 <filename>"
    exit 1
fi

# NOT - invert the condition
if [[ ! -f "$1" ]]; then
    echo "Not a file: $1"
    exit 1
elif [[ ! -d "$1" ]]; then
    echo "Not a directory: $1"
    exit 1
fi
